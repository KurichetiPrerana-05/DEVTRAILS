# ─── GigShield Unified Environment Variables ───────────────────────────────────
POSTGRES_DB=gigshield
POSTGRES_USER=gigshield_user
POSTGRES_PASSWORD=gigshield_pass

# Backend
NODE_ENV=development
PORT=3001
DATABASE_URL=postgres://gigshield_user:gigshield_pass@postgres:5432/gigshield
JWT_SECRET=gigshield_jwt_secret_dev
ADMIN_SECRET=gigshield_admin_secret_dev
REDIS_URL=redis://redis:6379
ML_SERVICE_URL=http://ml-service:8000

# Frontends (Baked in at build time)
VITE_API_URL=http://localhost:3001/api
VITE_API_BASE_URL=http://localhost:3001
VITE_ADMIN_TOKEN=gigshield_admin_secret_dev
