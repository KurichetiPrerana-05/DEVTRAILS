PORT=5000
DATABASE_URL=postgres://postgres:password@localhost:5432/gigshield
JWT_SECRET=your_secret
ML_SERVICE_URL=http://localhost:8000
# ── OTP / SMS Provider ─────────────────────────────────────────
# Set SMS_PROVIDER to one of: msg91 | twilio | awssns | console (dev)
SMS_PROVIDER=console

# MSG91 (recommended for India)
MSG91_AUTH_KEY=your_msg91_auth_key
MSG91_TEMPLATE_ID=your_otp_template_id

# Twilio (global)
TWILIO_ACCOUNT_SID=your_twilio_sid
TWILIO_AUTH_TOKEN=your_twilio_token
TWILIO_PHONE_NUMBER=+1xxxxxxxxxx

# ── Socket.io ──────────────────────────────────────────────────
CORS_ORIGIN=http://localhost:5173

# ── Open-Meteo weather API ─────────────────────────────────────
# No API key needed for Open-Meteo (free tier). Timeout in seconds:
WEATHER_API_TIMEOUT=5
